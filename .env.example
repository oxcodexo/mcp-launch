# MCP shared bearer token (used by all supergateway instances)
MCP_BEARER_TOKEN=my_api_key

# Your ngrok auth token — get it from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_token_here

# Optional: set a static ngrok domain (paid plan) or leave empty for dynamic URL
# e.g. NGROK_URL=https://my-static-domain.ngrok-free.app
NGROK_URL=
