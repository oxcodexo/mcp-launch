# MCP shared bearer token (used by all supergateway instances)
MCP_BEARER_TOKEN=change_me

# Your ngrok auth token — get it from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=change_me

# Your static ngrok domain (e.g. worthy-gorgeous-guppy.ngrok-free.app)
NGROK_DOMAIN=change_me
