# MCP shared bearer token (used by all supergateway instances)
MCP_BEARER_TOKEN=change_me

# Your ngrok auth token — get it from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=change_me

# Your static ngrok domain (e.g. static-given-domain.ngrok-free.app)
NGROK_DOMAIN=change_me

# Host path to mount into the agent sandbox
# The agent can read/write/execute anything inside /workspace
SANDBOX_MOUNT_PATH=/home/your-user/projects

# On Linux, files created inside the sandbox are owned by root on the host unless
# these match your host user. Run `id -u` and `id -g` to get the right values.
# Mac and Windows users can leave these unset (Docker Desktop handles ownership transparently).
UID=1000
GID=1000
