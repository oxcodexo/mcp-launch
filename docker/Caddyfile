:9876 {

    # ── Filesystem MCP ─────────────────────────────────
    # Endpoint: /filesystem/mcp
    route /filesystem/* {
        uri strip_prefix /filesystem
        reverse_proxy mcp-filesystem:9001
    }

    # ── Terminal MCP ─────────────────────────────────
    # Endpoint: /terminal/mcp
    # Proxies to host loopback (mcp-terminal runs natively on the host)
    route /terminal/* {
        uri strip_prefix /terminal
        reverse_proxy host.docker.internal:9002
    }

}
